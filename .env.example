# DeepSeek MCP Gateway
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3
# DEEPSEEK_CHAT_MODEL=deepseek-chat  # or deepseek-v3.2

# Hillhorn MCP - экономия API
# HILLHORN_MAX_TOKENS=1200  # default, снижает расход output ($1.10/1M)

# NWF memory
NWF_MEMORY_PATH=data/deepseek_memory
NWF_MEMORY_ADAPTER_PATH=data/nwf_opencloud

# OpenCloud/Moltbot workspace (default ~/.openclaw/workspace)
MOLTBOT_WORKSPACE=C:\Hillhorn\workspace

# Hugging Face (optional, for semantic embeddings in NWF adapter)
HF_TOKEN=hf-your-token-here
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
